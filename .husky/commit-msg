#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Validate commit message format using commitlint
# Pattern: type(scope)?: message or type: message
# Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci

COMMIT_MSG=$(cat "$1")
COMMIT_PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci)(\([a-z\-]+\))?: .{3,}$"

if ! echo "$COMMIT_MSG" | grep -qiE "$COMMIT_PATTERN"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Expected format: type: message"
  echo "Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci"
  echo ""
  echo "Examples:"
  echo "  ✓ feat: Add user authentication"
  echo "  ✓ fix: Handle null values in parser"
  echo "  ✓ ci: Add unit tests to workflow"
  echo ""
  echo "Your message:"
  echo "  $COMMIT_MSG"
  echo ""
  exit 1
fi

exit 0
