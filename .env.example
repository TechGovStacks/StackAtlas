# Environment variables for StackAtlas development

# Application version (git tag or version number)
# Default: read from package.json if not set
VITE_APP_VERSION=0.0.60

# Current git commit SHA for version tracking
# Usually set by CI/CD pipelines
VITE_COMMIT_SHA=

# Brand/project URL (used in header/footer)
# Default: https://techgovstacks.github.io/StackAtlas/
VITE_BRAND_URL=

# Enable Progressive Web App features
# Set to 'true' in production builds
VITE_ENABLE_PWA=false
